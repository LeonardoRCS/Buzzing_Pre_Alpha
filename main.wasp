app Buzzing {
  wasp: {
    version: "^0.21.1"
  },
  title: "Buzzing - Public Transport Monitoring"
}

route RootRoute { path: "/", to: Main }
page Main { component: import { Main } from "@src/client/Main" }

query getBusTrips {
  fn: import { getBusTrips } from "@src/server/queries",
  entities: [BusTrip]
}
